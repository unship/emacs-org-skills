; -*- mode: emacs-lisp; lexical-binding: t; no-byte-compile: t -*-

;; Explicitly set main file
(setf eldev-project-main-file "elisp/claude-orgmode.el")

;; Use package archives
(eldev-use-package-archive 'gnu)
(eldev-use-package-archive 'melpa)

;; Additional dependencies not auto-detected.
;; The test suite mocks the vulpea backend entirely (an in-memory note store
;; plus `fset' stubs in test/test-helper.el), so no note-taking backend package
;; (vulpea / org-roam) needs to be installed to run the tests.
;; org-download is only `require'd lazily inside
;; `claude-orgmode-attach-file-to-references' (never at load time), so it is not
;; needed to load or test the package either.

;; Add elisp directory to load path
(add-to-list 'load-path (expand-file-name "elisp" eldev-project-dir))

;; Allow loading test helpers
(eldev-add-loading-roots 'test "test")

;; Tell checkdoc not to demand two spaces after a period
(setq sentence-end-double-space nil)
